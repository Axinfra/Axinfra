generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AuditLog {
  id         String   @id @default(uuid())
  projectId  String
  actorId    String
  role       String
  actionType String
  entityType String
  entityId   String
  beforeJson String?
  afterJson  String?
  reason     String?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id])
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([projectId])
  @@index([projectId, actionType])
  @@index([projectId, createdAt])
  @@index([projectId, actorId, createdAt])
}

model BOQ {
  id          String        @id @default(uuid())
  projectId   String
  phaseId     String?       @unique
  status      String        @default("DRAFT")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       Phase?        @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  items       BOQItem[]
  revisions   BOQRevision[]

  @@index([projectId])
  @@index([projectId, createdAt])
}

model BOQItem {
  id             String             @id @default(uuid())
  boqId          String
  description    String
  unit           String
  plannedQty     Float
  rate           Float
  plannedValue   Float
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  boq            BOQ                @relation(fields: [boqId], references: [id], onDelete: Cascade)
  milestoneLinks MilestoneBOQLink[]

  @@index([boqId])
  @@index([boqId, createdAt])
}

model BOQRevision {
  id             String    @id @default(uuid())
  boqId          String
  revisionNumber Int
  reason         String
  changesJson    String
  approvedAt     DateTime?
  approvedById   String?
  createdAt      DateTime  @default(now())
  boq            BOQ       @relation(fields: [boqId], references: [id], onDelete: Cascade)

  @@index([boqId])
  @@index([boqId, revisionNumber])
}

model CustomView {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  name      String
  config    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId, name])
  @@index([projectId])
  @@index([userId])
}

model EligibilityEvent {
  id                   String             @id @default(uuid())
  paymentEligibilityId String
  eventType            String
  fromState            String?
  toState              String
  actorId              String
  actorRole            String
  eligibleAmountBefore Float?
  eligibleAmountAfter  Float
  reasonCode           String?
  explanation          String?
  triggerEntityType    String?
  triggerEntityId      String?
  createdAt            DateTime           @default(now())
  actor                User               @relation(fields: [actorId], references: [id])
  paymentEligibility   PaymentEligibility @relation(fields: [paymentEligibilityId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
  @@index([eventType])
  @@index([paymentEligibilityId])
}

model Evidence {
  id            String         @id @default(uuid())
  milestoneId   String
  submittedById String
  submittedAt   DateTime       @default(now())
  qtyOrPercent  Float
  remarks       String?
  frozen        Boolean        @default(false)
  status        String         @default("SUBMITTED")
  reviewedAt    DateTime?
  reviewNote    String?
  updatedAt     DateTime       @updatedAt
  milestone     Milestone      @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  submittedBy   User           @relation(fields: [submittedById], references: [id])
  files         EvidenceFile[]

  @@index([milestoneId])
  @@index([status])
  @@index([submittedById])
  @@index([milestoneId, status])
  @@index([submittedById, status])
}

model EvidenceFile {
  id         String   @id @default(uuid())
  evidenceId String
  storageKey String
  fileName   String
  mimeType   String
  size       Int
  filePath   String   @default("")
  createdAt  DateTime @default(now())
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@index([evidenceId])
}

model FollowUp {
  id             String    @id @default(uuid())
  projectId      String
  type           String
  targetEntity   String
  targetEntityId String
  description    String
  status         String    @default("OPEN")
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolutionNote String?
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resolvedBy     User?     @relation(fields: [resolvedById], references: [id])

  @@index([projectId])
  @@index([resolvedById])
  @@index([status])
  @@index([type])
  @@index([projectId, status, type])
  @@index([projectId, type])
}

model Milestone {
  id                      String                     @id @default(uuid())
  projectId               String
  title                   String
  description             String?
  paymentModel            String                     @default("PROGRESS_BASED")
  plannedStart            DateTime?
  plannedEnd              DateTime?
  actualStart             DateTime?
  actualSubmission        DateTime?
  actualVerification      DateTime?
  // Schedule intelligence fields (Phase 1 additions)
  baselinePlannedEnd      DateTime?                  // Snapshot of original plannedEnd for baseline comparison
  baselinePlannedStart    DateTime?                  // Snapshot of original plannedStart
  sortOrder               Int                        @default(0) // Display order in Gantt
  plannedQtyOrPercent     Float                      @default(100)
  retentionPercent        Float                      @default(0)
  advancePercent          Float                      @default(0)
  value                   Float                      @default(0)
  isExtra                 Boolean                    @default(false)
  extraApprovedAt         DateTime?
  extraApprovedById       String?
  state                   String                     @default("DRAFT")
  vendorUserId            String?                    // Optional: assigned vendor user
  phaseId                 String?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  evidence                Evidence[]
  project                 Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorUser              User?                      @relation("MilestoneVendor", fields: [vendorUserId], references: [id])
  phase                   Phase?                     @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  boqLinks                MilestoneBOQLink[]
  transitions             MilestoneStateTransition[]
  paymentEligibility      PaymentEligibility?
  verifications           Verification[]
  successorDependencies   MilestoneDependency[]      @relation("DependencySuccessor")
  predecessorDependencies MilestoneDependency[]      @relation("DependencyPredecessor")

  @@index([projectId])
  @@index([state])
  @@index([vendorUserId])
  @@index([extraApprovedById])
  @@index([title])
  @@index([plannedEnd])
  @@index([phaseId])
  @@index([projectId, state])
  @@index([projectId, createdAt])
  @@index([vendorUserId, state])
}

model MilestoneBOQLink {
  id          String    @id @default(uuid())
  milestoneId String
  boqItemId   String
  plannedQty  Float
  createdAt   DateTime  @default(now())
  boqItem     BOQItem   @relation(fields: [boqItemId], references: [id], onDelete: Cascade)
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, boqItemId])
  @@index([boqItemId])
  @@index([milestoneId])
}

model MilestoneStateTransition {
  id          String    @id @default(uuid())
  milestoneId String
  fromState   String?
  toState     String
  actorId     String
  role        String
  reason      String?
  createdAt   DateTime  @default(now())
  actor       User      @relation(fields: [actorId], references: [id])
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([milestoneId])
  @@index([milestoneId, createdAt])
}

model PaymentEligibility {
  id                  String             @id @default(uuid())
  milestoneId         String             @unique
  boqValueCompleted   Float              @default(0)
  deductions          Float              @default(0)
  eligibleAmount      Float              @default(0)
  advanceAmount       Float              @default(0)
  remainingAmount     Float              @default(0)
  blockedAmount       Float              @default(0)
  state               String             @default("NOT_DUE")
  dueDate             DateTime?
  blockReasonCode     String?
  blockExplanation    String?
  blockedAt           DateTime?
  blockedByActorId    String?
  markedPaidAt        DateTime?
  markedPaidByActorId String?
  paidExplanation     String?
  lastCalculatedAt    DateTime           @default(now())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  events              EligibilityEvent[]
  milestone           Milestone          @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([state])
  @@index([state, dueDate])
}

model Project {
  id               String                  @id @default(uuid())
  name             String
  description      String?
  status           String                  @default("ONGOING")
  metadata         String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  isExampleProject Boolean                 @default(false)
  deletedAt        DateTime?
  auditLogs        AuditLog[]
  boqs             BOQ[]
  followUps        FollowUp[]
  milestones       Milestone[]
  phases           Phase[]
  roles            ProjectRole[]
  scheduleConfig   ProjectScheduleConfig?
  vendorMetrics    VendorMetrics[]
  projectMetrics   ProjectMetrics[]
  systemEvents     SystemEvent[]
  cashAdjustments  CashAdjustment[]
  privateCosts     PrivateCostEntry[]
  // Architecture module
  drawingSets      DrawingSet[]
  drawingRows      DrawingRow[]
  setRequests      SetRequest[]
  vendorRequests   VendorRequest[]
}

/// Dependency link between two milestones (CPM / Gantt edges)
model MilestoneDependency {
  id                 String    @id @default(uuid())
  predecessorId      String
  successorId        String
  /// Dependency type: FS=Finish-to-Start, SS=Start-to-Start, FF=Finish-to-Finish, SF=Start-to-Finish
  dependencyType     String    @default("FS")
  lagDays            Float     @default(0)
  createdAt          DateTime  @default(now())
  predecessor        Milestone @relation("DependencyPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor          Milestone @relation("DependencySuccessor", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
}

/// Per-project schedule configuration for delay cost estimation and display preferences
model ProjectScheduleConfig {
  id                    String   @id @default(uuid())
  projectId             String   @unique
  /// Project start date used as Gantt origin
  projectStartDate      DateTime?
  /// Estimated daily overhead cost in project currency (for delay cost estimation)
  dailyOverheadCost     Float    @default(0)
  /// Contractual penalty rate per day of delay (fraction, e.g. 0.001 = 0.1%)
  penaltyRatePerDay     Float    @default(0)
  /// Opportunity cost multiplier (optional)
  opportunityCostFactor Float    @default(1.0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectRole {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([projectId, role])
}

model User {
  id                      String                     @id @default(uuid())
  name                    String
  email                   String                     @unique
  hashedPassword          String
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  auditLogs               AuditLog[]
  eligibilityEvents       EligibilityEvent[]
  evidence                Evidence[]
  followUps               FollowUp[]
  transitions             MilestoneStateTransition[]
  projectRoles            ProjectRole[]
  verifications           Verification[]
  assignedMilestones      Milestone[]                @relation("MilestoneVendor")
  vendorMetrics           VendorMetrics[]
  systemEventsActor       SystemEvent[]              @relation("SystemEventActor")
  cashAdjustments         CashAdjustment[]           @relation("CashAdjustmentCreator")
  privateCosts            PrivateCostEntry[]         @relation("PrivateCostCreator")
  // Architecture module
  drawingSetsCreated      DrawingSet[]               @relation("DrawingSetCreator")
  drawingSetsRequested    DrawingSet[]               @relation("DrawingSetRequester")
  drawingSetsPaid         DrawingSet[]               @relation("DrawingSetPaymentReleaser")
  drawingRows             DrawingRow[]               @relation("DrawingRowCreator")
  drawingRowsPaid         DrawingRow[]               @relation("DrawingRowPaymentReleaser")
  drawingVersionsUploaded DrawingVersion[]           @relation("DrawingVersionUploader")
  drawingVersionsReviewed DrawingVersion[]           @relation("DrawingVersionReviewer")
  setRequests             SetRequest[]               @relation("SetRequestCreator")
  vendorRequestsSubmitted  VendorRequest[]     @relation("VendorRequestSubmitter")
  vendorRequestsResponded  VendorRequest[]     @relation("VendorRequestResponder")
  vendorRequestFiles       VendorRequestFile[] @relation("VendorRequestFileUploader")
}

model Verification {
  id                    String    @id @default(uuid())
  milestoneId           String
  verifiedById          String
  verifiedAt            DateTime  @default(now())
  notes                 String?
  qtyVerified           Float
  valueEligibleComputed Float
  milestone             Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  verifiedBy            User      @relation(fields: [verifiedById], references: [id])

  @@index([milestoneId])
  @@index([milestoneId, verifiedAt])
  @@index([verifiedById])
}

/// Vendor-level metrics snapshot for a project (computed periodically)
model VendorMetrics {
  id                    String   @id @default(uuid())
  projectId             String
  vendorUserId          String
  period                String
  totalMilestones       Int      @default(0)
  completedOnTime       Int      @default(0)
  completedLate         Int      @default(0)
  avgDelayDays          Float    @default(0)
  qualityScore          Float    @default(0)
  escalationCount       Int      @default(0)
  totalValueDelivered   Float    @default(0)
  totalValuePaid        Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor                User     @relation(fields: [vendorUserId], references: [id])

  @@unique([projectId, vendorUserId, period])
  @@index([projectId])
  @@index([vendorUserId])
}

/// Project-level aggregated metrics snapshot (computed periodically)
model ProjectMetrics {
  id                    String   @id @default(uuid())
  projectId             String
  period                String
  totalBudget           Float    @default(0)
  spentToDate           Float    @default(0)
  earnedValue           Float    @default(0)
  plannedValue          Float    @default(0)
  costVariance          Float    @default(0)
  scheduleVariance      Float    @default(0)
  cpi                   Float    @default(0)
  spi                   Float    @default(0)
  milestonesTotal       Int      @default(0)
  milestonesComplete    Int      @default(0)
  milestonesOverdue     Int      @default(0)
  healthStatus          String   @default("GREEN")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, period])
  @@index([projectId])
}

/// System-wide event log for infrastructure-level events
model SystemEvent {
  id          String   @id @default(uuid())
  eventType   String
  severity    String   @default("INFO")
  actorId     String?
  projectId   String?
  entityType  String?
  entityId    String?
  message     String
  metadata    String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("SystemEventActor", fields: [actorId], references: [id])
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([eventType])
  @@index([severity])
  @@index([actorId])
  @@index([projectId])
  @@index([createdAt])
}

/// Builder-private cash adjustment (credit/debit) for internal financial tracking
model CashAdjustment {
  id          String   @id @default(uuid())
  projectId   String
  description String
  amount      Float
  type        String
  reason      String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("CashAdjustmentCreator", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
}

/// Builder-private cost entry not visible to PMC / Vendor / other roles
model PrivateCostEntry {
  id          String    @id @default(uuid())
  projectId   String
  description String
  amount      Float
  category    String
  vendor      String?
  notes       String?
  incurredAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("PrivateCostCreator", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
  @@index([category])
}

model Phase {
  id         String      @id @default(uuid())
  projectId  String
  name       String
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  boq        BOQ?
  milestones Milestone[]

  @@index([projectId])
  @@index([projectId, sortOrder])
}

// ── Architecture Module ───────────────────────────────────────────────────────

/// A set of drawings (e.g. "Working Drawing Set 1") with a cost and lifecycle
model DrawingSet {
  id                String    @id @default(uuid())
  projectId         String
  name              String
  description       String?
  cost              Float     @default(0)
  currency          String    @default("INR")
  /// DRAFT | SUBMITTED_TO_PMC | REQUESTED | IN_PROGRESS | DELIVERED | APPROVED | PAID
  status            String    @default("DRAFT")
  createdById       String
  requestedById     String?
  requestedAt       DateTime?
  dueDate           DateTime?
  deliveredAt       DateTime?
  approvedAt        DateTime?
  paidAt            DateTime?
  paymentReleasedBy String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User        @relation("DrawingSetCreator", fields: [createdById], references: [id])
  requestedBy      User?       @relation("DrawingSetRequester", fields: [requestedById], references: [id])
  paymentReleaser  User?       @relation("DrawingSetPaymentReleaser", fields: [paymentReleasedBy], references: [id])
  rows             DrawingRow[]
  requests         SetRequest[]

  @@index([projectId])
  @@index([createdById])
  @@index([projectId, status])
}

/// A single drawing row — one entry in the master drawing register
model DrawingRow {
  id          String    @id @default(uuid())
  projectId   String
  setId       String?
  serialNo    Int
  category    String
  name        String
  /// BASEMENT | GROUND_FLOOR | FIRST_FLOOR | SECOND_FLOOR | TERRACE | ALL_FLOORS
  floor       String    @default("ALL_FLOORS")
  description String?
  /// PENDING | SUBMITTED | APPROVED | REJECTED
  status      String    @default("PENDING")
  dueDate     DateTime?
  createdById String
  /// Per-drawing payment release (OWNER)
  paidAt      DateTime?
  paidById    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  set        DrawingSet?  @relation(fields: [setId], references: [id], onDelete: SetNull)
  createdBy  User         @relation("DrawingRowCreator", fields: [createdById], references: [id])
  paidBy     User?        @relation("DrawingRowPaymentReleaser", fields: [paidById], references: [id])
  versions   DrawingVersion[]

  @@index([projectId])
  @@index([setId])
  @@index([projectId, status])
  @@index([projectId, serialNo])
}

/// A specific version of a drawing (v0, v1, v2 …)
model DrawingVersion {
  id              String    @id @default(uuid())
  drawingRowId    String
  versionNumber   Int
  /// PDF | URL
  uploadType      String    @default("PDF")
  fileUrl         String
  fileName        String?
  fileSizeKb      Int?
  uploadedById    String
  uploadedAt      DateTime  @default(now())
  reviewedById    String?
  reviewedAt      DateTime?
  /// PENDING | APPROVED | REJECTED
  reviewStatus    String    @default("PENDING")
  rejectionReason String?
  isCurrent       Boolean   @default(true)

  drawingRow DrawingRow @relation(fields: [drawingRowId], references: [id], onDelete: Cascade)
  uploadedBy User       @relation("DrawingVersionUploader", fields: [uploadedById], references: [id])
  reviewedBy User?      @relation("DrawingVersionReviewer", fields: [reviewedById], references: [id])

  @@index([drawingRowId])
  @@index([uploadedById])
  @@index([drawingRowId, isCurrent])
  @@index([drawingRowId, versionNumber])
}

/// A formal PMC request for a drawing set
model SetRequest {
  id            String    @id @default(uuid())
  setId         String
  projectId     String
  requestedById String
  requestedAt   DateTime  @default(now())
  dueDate       DateTime?
  note          String?
  /// PENDING | ACCEPTED | DECLINED
  status        String    @default("PENDING")

  set          DrawingSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy  User       @relation("SetRequestCreator", fields: [requestedById], references: [id])

  @@index([setId])
  @@index([projectId])
}

/// A formal request or submission between any project parties (bidirectional)
model VendorRequest {
  id            String    @id @default(uuid())
  projectId     String
  submittedById String
  senderRole    String    @default("VENDOR")   // VENDOR | PMC | CONSULTANT | OWNER
  category      String    @default("REQUEST")  // REQUEST | SUBMISSION
  title         String
  description   String
  type          String    @default("RFI")
  priority      String    @default("NORMAL")
  dueDate       DateTime?
  sendTo        String    @default("PMC")      // PMC | CONSULTANT | OWNER | VENDOR | BOTH | ALL
  refNumber     String?
  status        String    @default("PENDING")
  responseNote  String?
  respondedById String?
  respondedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submittedBy User                @relation("VendorRequestSubmitter", fields: [submittedById], references: [id])
  respondedBy User?               @relation("VendorRequestResponder", fields: [respondedById], references: [id])
  files       VendorRequestFile[]

  @@index([projectId])
  @@index([submittedById])
  @@index([senderRole])
  @@index([status])
  @@index([category])
  @@index([sendTo])
  @@index([projectId, status])
  @@index([projectId, category])
  @@index([projectId, createdAt])
  @@index([projectId, sendTo])
  @@index([projectId, submittedById])
}

/// File attachment for a vendor request
model VendorRequestFile {
  id           String        @id @default(uuid())
  requestId    String
  storageKey   String
  fileName     String
  mimeType     String
  fileSize     Int
  uploadedById String
  createdAt    DateTime      @default(now())

  request    VendorRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation("VendorRequestFileUploader", fields: [uploadedById], references: [id])

  @@index([requestId])
}
