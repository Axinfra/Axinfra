# =========================
# Database (PostgreSQL)
# =========================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axinfra

# =========================
# Authentication
# =========================
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
SESSION_EXPIRY_HOURS=24

# =========================
# File Storage
# =========================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# =========================
# Cron / Scheduled Tasks
# =========================
CRON_SECRET=""

# =========================
# Follow-up Thresholds (in days)
# =========================
PENDING_REVIEW_THRESHOLD_DAYS=3
PENDING_VERIFICATION_THRESHOLD_DAYS=5
PAYMENT_DUE_SOON_THRESHOLD_DAYS=7
PAYMENT_BLOCKED_THRESHOLD_DAYS=14

# =========================
# Cache (Upstash Redis)
# =========================
# Optional in local dev — if unset, falls back to an in-process Map.
# REQUIRED in production (Vercel) for cache to survive cold starts.
# Create a free DB at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# =========================
# App
# =========================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
