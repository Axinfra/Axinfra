# =========================
# Database (PostgreSQL - Neon)
# =========================
# Pooled connection via PgBouncer — used by the app at runtime (Vercel serverless)
# Get from: Neon Console → your project → Connection Details → select "Prisma" → Pooled connection
DATABASE_URL="postgresql://<user>:<password>@<ep-xxx-pooler>.<region>.aws.neon.tech/<dbname>?sslmode=require&pgbouncer=true"

# Direct connection — used ONLY by: prisma migrate deploy / prisma db push (bypasses pooler)
# Get from: Neon Console → your project → Connection Details → select "Prisma" → Direct connection
DIRECT_URL="postgresql://<user>:<password>@<ep-xxx>.<region>.aws.neon.tech/<dbname>?sslmode=require"

# =========================
# Authentication
# =========================
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""
SESSION_EXPIRY_HOURS=24

# =========================
# File Storage (Vercel Blob — production)
# =========================
# Create a Blob store: Vercel Dashboard → Storage → Create → Blob → Connect to project
# Copy BLOB_READ_WRITE_TOKEN from the store settings
# Falls back to local disk (./uploads) in dev if left empty
BLOB_READ_WRITE_TOKEN=""
MAX_FILE_SIZE_MB=10

# Optional storage fallbacks. Leave empty when using Vercel Blob.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="evidence"
R2_BUCKET=""
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
UPLOAD_DIR="./uploads"

# =========================
# Cron / Scheduled Tasks
# =========================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# =========================
# Follow-up Thresholds (in days) — optional, these are the defaults
# =========================
PENDING_REVIEW_THRESHOLD_DAYS=3
PENDING_VERIFICATION_THRESHOLD_DAYS=5
PAYMENT_DUE_SOON_THRESHOLD_DAYS=7
PAYMENT_BLOCKED_THRESHOLD_DAYS=14

# =========================
# Cache (Upstash Redis) — REQUIRED in production
# =========================
# Survives Vercel cold starts; falls back to in-process Map in local dev if unset
# Create a free Redis DB at https://console.upstash.com → Redis → Create database
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =========================
# App
# =========================
# Local dev: http://localhost:3000
# Production: set to your Vercel deployment URL (also add this in Vercel env vars)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Optional Google OAuth. Required only if "Continue with Google" should work.
# Google Cloud Console redirect URI must exactly match this value.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://your-app.vercel.app/api/auth/google/callback"

# =========================
# Admin Portal
# =========================
# Comma-separated list of emails that have access to /admin/*
# If unset, falls back to any user with OWNER role in at least one project
ADMIN_EMAILS="you@axinfra.in,admin@axinfra.in"

# =========================
# Email (Resend)
# =========================
# Sign up at https://resend.com → API Keys → Create API Key
# Then verify your domain: Resend Dashboard → Domains → Add domain → add axinfra.in
# Add the 3 DNS records Resend shows you (SPF, DKIM, DMARC) to your domain registrar
# These records do NOT conflict with Gmail MX records — both work simultaneously
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Axinfra <dev@axinfra.in>"
SUPPORT_EMAIL="dev@axinfra.in"
